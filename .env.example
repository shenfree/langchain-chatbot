# 复制本文件为 .env，并填写自己的 API Key。
# .env 不应提交到 Git 仓库。

# 默认 DeepSeek / 旧版通用配置
API_KEY=
API_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# Qwen / DashScope 配置
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# MySQL 密码只放在 .env 中，不写入 config.yaml
MYSQL_PASSWORD=

# 可选：如需用环境变量覆盖 MySQL 非敏感配置，可以自行启用
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_DATABASE=langchain_chat
