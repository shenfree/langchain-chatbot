# 复制本文件为 .env，然后填写自己的真实密钥和本地密码。
# .env 包含敏感信息，不应提交到 Git 仓库。

# -----------------------------------------------------------------------------
# Model API Keys
# -----------------------------------------------------------------------------

# DeepSeek / 旧版通用配置
API_KEY=
API_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# Qwen / DashScope 配置
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# -----------------------------------------------------------------------------
# MySQL
# -----------------------------------------------------------------------------

# MySQL 密码只放在 .env 中，不写入 config.yaml。
MYSQL_PASSWORD=

# 可选：如需用环境变量临时覆盖 config.yaml 中的 MySQL 非敏感配置，可以启用下面几项。
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_DATABASE=langchain_chat

# -----------------------------------------------------------------------------
# Optional Runtime Settings
# -----------------------------------------------------------------------------

# 当前项目默认从 config.yaml 读取 LLM 参数；如后续需要，可在代码中扩展读取这些变量。
# LLM_TIMEOUT=60
# LLM_MAX_RETRIES=3
# LLM_TEMPERATURE=0.7
